@model IEnumerable<coffeeshop.Models.Product>

<div class="row mt-4">
    @foreach (var item in Model)
    {
        <div class="col-12 col-md-6 col-lg-4">
            <div class="item-wrapper">
                <div class="item-img">
                    <img src="@item.ImageUrl" alt="Coffee Shop" style="width:100px;">
                </div>
                <div class="item-content">
                    <a asp-controller="Products" asp-action="Detail" asp-route-id="@item.Id" target="_blank">
                        <h6><strong>@item.Name</strong></h6>
                    </a>
                    <p>@item.Price.ToString("C")</p>
                </div>
                <div class="item-footer">
                    <a href="#" class="btn btn-primary">Add to cart</a>
                </div>
            </div>
        </div>
    }
</div>
